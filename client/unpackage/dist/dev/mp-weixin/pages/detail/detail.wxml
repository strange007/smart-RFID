<view class="wrap"><view class="dev-area"><view data-event-opts="{{[['tap',[['goLineChartTemp',['$event']]]]]}}" class="dev-cart" bindtap="__e"><view><view class="dev-name">温度</view><image class="dev-logo" src="../../static/temp.png" mode></image></view><view class="dev-data">{{temp+" ℃"}}</view></view><view data-event-opts="{{[['tap',[['goLineChartHumi',['$event']]]]]}}" class="dev-cart" bindtap="__e"><view><view class="dev-name">湿度</view><image class="dev-logo" src="../../static/humi.png" mode></image></view><view class="dev-data">{{humi+" %"}}</view></view><view data-event-opts="{{[['tap',[['goLineChartSmog',['$event']]]]]}}" class="dev-cart" bindtap="__e"><view><view class="dev-name">烟雾</view><image class="dev-logo" src="../../static/smog.png" mode></image></view><view class="dev-data">{{smog}}</view></view><view class="dev-cart"><view><view class="dev-name">风扇</view><image class="dev-logo" src="../../static/fan.png" mode></image></view><switch checked="{{fan}}" color="#2b9939" data-event-opts="{{[['change',[['onFanSwitch',['$event']]]]]}}" bindchange="__e"></switch></view><block wx:if="{{beep==true}}"><view class="dev-cart" style="background-color:red;">危险</view></block><block wx:else><view class="dev-cart" style="background-color:green;">安全</view></block><view class="device-cart-l"><view><view class="dev-name">烟雾阈值</view></view><view class="ctrl-slider"><slider value="{{smog_th}}" min="0" max="5" step="0.1" block-size="20" show-value="{{true}}" data-event-opts="{{[['change',[['sliderChangeSmogTh',['$event','slider1']]]]]}}" bindchange="__e"></slider></view></view><view class="device-cart-l"><view><view class="dev-name">风扇调速</view></view><view class="ctrl-slider"><slider value="{{fan_adj}}" min="0" max="100" step="25" block-size="20" show-value="{{true}}" data-event-opts="{{[['change',[['sliderChangeFan',['$event','slider2']]]]]}}" bindchange="__e"></slider></view></view></view></view>