#ifndef __RFID_H__
#define __RFID_H__

/**

*/

#include "stm32f10x.h"

#define TAG_CACHE_SIZE   10
#define EPC_LEN          12
#define TIME_WINDOW_MS   10000   // 10秒(单位毫秒)
#define RSSI_THRESHOLD_DEFAULT 196  // dBm RSSI数值,设定大于-60dBM的信号良好,-60的补码为C4,十进制为196
								   //RSSI在-60~0算良好，越大越强,补码越高(RFID读写器拿到的数据是补码)

typedef struct
{
    uint8_t  epc[EPC_LEN];
    uint32_t last_time;     // 上次识别时间
    uint8_t  valid;
int8_t   rssi;        // 信号强度
} TagNode;


void RFID_SearchOnce(void);
uint8_t RFID_GetRxFlag(void);
void Serial_SendByte(uint8_t Byte);
void Serial_SendArray(uint8_t *Array, uint16_t Length);
void Serial_SendString(char *String);
void Serial_SendNumber(uint32_t Number, uint8_t Length);
void RFID_Clear(void);
u8 RFID_Unpacket(void);

uint8_t RFID_CheckDuplicate(uint8_t *epc);
void RFID_CleanExpired(void);
#endif

